{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and social links.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "personality": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "friends": {
          "type": "object",
          "description": "Map of userId to boolean for relationship tracking."
        }
      },
      "required": ["id", "email", "username"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "A movie entry in a user's collection, keyed by tmdbId.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieData": { "type": "object", "description": "Full movie details object for relational clarity." },
        "addedDate": { "type": "string", "format": "date-time" },
        "isWatched": { "type": "boolean" },
        "watchDate": { "type": "string", "format": "date-time" },
        "personalRating": { "type": "number" },
        "notes": { "type": "string" },
        "rewatchCount": { "type": "number" },
        "isFavorite": { "type": "boolean" },
        "remindMe": { "type": "boolean" }
      },
      "required": ["userId", "movieId", "isWatched"]
    },
    "SceneMemory": {
      "title": "SceneMemory",
      "type": "object",
      "description": "A specific cinematic moment captured by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "movieId": { "type": "string" },
        "movieTitle": { "type": "string" },
        "posterUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "quote": { "type": "string" },
        "note": { "type": "string" },
        "addedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "movieId", "timestamp"]
    },
    "WatchParty": {
      "title": "WatchParty",
      "type": "object",
      "description": "A collaborative movie watching room.",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["voting", "ready", "finished"] },
        "selectedMovieId": { "type": "string" },
        "selectedMovieTitle": { "type": "string" },
        "selectedMoviePoster": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "A user alert for invites and events.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "partyId": { "type": "string" },
        "partyTitle": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "A social comment on a movie.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "watchlistEntryId": { "type": "string" },
        "text": { "type": "string" },
        "commentDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/watchlist/{movieId}": {
      "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
      "description": "Personal movie tracking queue."
    },
    "/users/{userId}/sceneMemories/{memoryId}": {
      "schema": { "$ref": "#/backend/entities/SceneMemory" },
      "description": "Cinematic highlights and notes."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": { "$ref": "#/backend/entities/Notification" },
      "description": "Activity alerts and invites."
    },
    "/watchParties/{partyId}": {
      "schema": { "$ref": "#/backend/entities/WatchParty" },
      "description": "Watch party room metadata."
    },
    "/watchParties/{partyId}/members/{userId}": {
      "schema": { "type": "object" },
      "description": "Party participants."
    },
    "/watchParties/{partyId}/nominations/{nomId}": {
      "schema": { "type": "object" },
      "description": "Movie suggestions for the party."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/backend/entities/Comment" },
      "description": "Global movie discussions."
    }
  }
}
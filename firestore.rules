
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MOVIE WATCHLIST APP SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for personal data (profiles, watchlists) 
     * while enabling social features through a "Friends" access model. Public movie data is 
     * globally readable by authenticated users but strictly read-only from the client.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isFriendOf(targetUserId) {
      // Robust check for friend status that handles missing documents or fields safely
      let userPath = /databases/$(database)/documents/users/$(targetUserId);
      return isSignedIn() && 
             exists(userPath) &&
             request.auth.uid in get(userPath).data.get('friends', {});
    }

    function isDataOwner(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    function isExistingDataOwner(fieldName) {
      return resource != null && isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    // --- Collection Rules ---

    // Top-level users match
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isFriendOf(userId);
      allow create: if isOwner(userId); 
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      // Explicitly allow subcollections for the owner and their friends
      match /watchlist/{watchlistEntryId} {
        allow read: if isOwner(userId) || isFriendOf(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      match /sceneMemories/{memoryId} {
        allow read: if isOwner(userId) || isFriendOf(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    // Movies are read-only for all signed-in users
    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Social comments are readable by any authenticated user
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Other metadata collections
    match /genres/{genreId} {
      allow read: if isSignedIn();
    }
    match /moviePersonalityTypes/{typeId} {
      allow read: if isSignedIn();
    }
  }
}

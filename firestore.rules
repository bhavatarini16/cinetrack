rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CineTrack Security Rules
     * 
     * Core Philosophy:
     * - Users have full access to their own data tree.
     * - Watch Parties and Comments are collaborative.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and nested personal data (Watchlist, SceneMemories, etc.)
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Explicitly allow access to subcollections for listing operations
      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }
      match /sceneMemories/{memoryId} {
        allow read, write: if isOwner(userId);
      }
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Watch Parties - Collaborative movie watching rooms.
     */
    match /watchParties/{partyId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }

      match /nominations/{nomId} {
        allow read, write: if isSignedIn();
      }
    }

    /**
     * @description Public movie discussion comments.
     */
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
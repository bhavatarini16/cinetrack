rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CineTrack Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust, multi-layered security model for the CineTrack application. 
     * It prioritizes user privacy through strict ownership patterns while enabling global access 
     * to the movie catalog. Administrative control is handled via a Database Access Control (DBAC) 
     * pattern, avoiding the complexity of custom claims.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles and preferences.
     * - /users/{userId}/watchlistItems/{id}: User-specific movie interactions (nested for path-based ownership).
     * - /friendships/{id}: Shared documents between two users representing a relationship.
     * - /movies, /genres, /actors, /cinemaPersonalityTypes: Publicly readable catalog data.
     * - /roles_admin/{userId}: Internal collection to designate administrative users.
     * 
     * Key Security Decisions:
     * 1. Path-Based Ownership: User data is nested under their Auth UID, allowing rules to verify 
     *    ownership without extra database lookups.
     * 2. DBAC (Roles): Administrative privileges are granted by the existence of a document 
     *    in the /roles_admin collection.
     * 3. Denormalization for Authorization: The Friendship entity includes both user IDs 
     *    directly in the document, and WatchlistItems include the userId, ensuring rules can 
     *    make decisions using only the document's own data (resource.data).
     * 4. Structural Segregation: Public catalog data is separated from private user data 
     *    to simplify list operations and prevent accidental data leakage.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document already exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the authenticated user has administrative privileges via DBAC. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Verifies if the user is one of the two participants in a friendship. */
    function isFriend(friendData) {
      return isSignedIn() && (request.auth.uid == friendData.user1Id || request.auth.uid == friendData.user2Id);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow get, create, update: if isOwner(userId)
     * @deny list: if true (Users cannot be listed globally)
     * @principle Enforces path-based ownership and relational integrity for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      /**
       * @description Rules for Watchlist Items. Nested under the user for strict ownership.
       * @path /users/{userId}/watchlistItems/{itemId}
       * @allow list: (list) if request.auth.uid == userId
       * @deny create: (create) if request.resource.data.userId != userId
       * @principle Nesting ensures Query-Ability Security Rules (QAPs) are met for listing.
       */
      match /watchlistItems/{watchlistItemId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Movie Catalog (Movies, Genres, Actors, Personality Types).
     * @path /{collection}/{id}
     * @allow get, list: if true (Publicly readable)
     * @deny write: if !isAdmin()
     * @principle Provides global read access while restricting modifications to admins.
     */
    match /movies/{movieId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /genres/{genreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /actors/{actorId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cinemaPersonalityTypes/{typeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Friendships. Access is shared between the two involved users.
     * @path /friendships/{friendshipId}
     * @allow get: (get) if auth.uid is user1Id or user2Id
     * @deny list: (list) if query does not filter by auth.uid
     * @principle Uses denormalized user IDs to ensure Authorization Independence.
     */
    match /friendships/{friendshipId} {
      allow get: if isFriend(resource.data);
      // QAP: Client must filter by user1Id == uid OR user2Id == uid
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && (request.resource.data.user1Id == request.auth.uid || request.resource.data.user2Id == request.auth.uid);
      allow update: if resource != null && isFriend(resource.data) && (request.resource.data.user1Id == resource.data.user1Id && request.resource.data.user2Id == resource.data.user2Id);
      allow delete: if resource != null && isFriend(resource.data);
    }

    /**
     * @description Administrative Roles (DBAC). Only admins can view or modify roles.
     * @path /roles_admin/{userId}
     * @allow get: if isOwner(userId)
     * @deny create, update, delete: if !isAdmin()
     * @principle Securely manages user privileges without relying on custom claims.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
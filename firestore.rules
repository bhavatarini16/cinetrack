
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // Users have full recursive access to their own data tree (watchlist, sceneMemories, etc.)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Watch Parties are collaborative
    match /watchParties/{partyId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }

      match /nominations/{nomId} {
        allow read, write: if isSignedIn();
      }
    }

    // Comments are public to read, restricted to write
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}

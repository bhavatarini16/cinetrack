rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CineTrack Security Rules
     * 
     * Core Philosophy:
     * - Users have full access (read/write/list) to their own profiles and private subcollections.
     * - Watch Parties are readable by any signed-in user, but only the host or members can perform specific mutations.
     * - Comments are public for reading, but restricted for creation and editing.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description User Profiles and their private subcollections (Watchlist, Memories, Notifications).
     */
    match /users/{userId} {
      // Allow the owner full access to their own root profile
      allow read, write: if isOwner(userId);

      // User's private watchlist (keyed by movie tmdbId)
      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }

      // User's private cinematic memories
      match /sceneMemories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      // User's private notifications
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Watch Parties - Collaborative movie watching rooms.
     */
    match /watchParties/{partyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow host to delete, allow host/members to update status/metadata
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      // Participants in a specific watch party
      match /members/{memberId} {
        allow read: if isSignedIn();
        // Allow a user to join themselves or the host to invite/add others
        allow write: if isSignedIn();
      }

      // Movie suggestions and votes
      match /nominations/{nomId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    /**
     * @description Public movie discussion comments.
     */
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
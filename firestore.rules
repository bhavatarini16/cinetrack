
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // Users have full authority over their own profile and all its subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /sceneMemories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Watch Parties are collaborative spaces
    match /watchParties/{partyId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }

      match /nominations/{nominationId} {
        allow read, write: if isSignedIn();
      }
    }

    // Comments are public to read, restricted to signed-in authors for writing
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
